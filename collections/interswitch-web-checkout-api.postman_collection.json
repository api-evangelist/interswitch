  "info": {
    "_postman_id": "582a7221-2ee5-4306-82ee-1e89bb4ddc68",
    "name": "Interswitch Web Checkout API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Interswitch Web Checkout (formerly Webpay) is the company's hosted payment\ngateway. Two integration modes are supported: an inline JavaScript popup\nloaded from `inline-checkout.js`, and a Web Redirect form POST to\n`/collections/w/pay`. After payment, merchants must perform a server-side\nrequery against `/collections/api/v1/gettransaction.json` and verify both\nthe response code (`00`) and the returned amount before delivering value.\n\n\nContact Support:\n Name: Interswitch Developer Support",
      "type": "text/plain"
    }
  }
