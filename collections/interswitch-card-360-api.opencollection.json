            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Block Card"
        },
        {
          "info": {
            "name": "Unblock Card",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://sandbox.interswitchng.com/card-360/api/v1/cards/:cardId/unblock",
