    {
      "info": {
        "name": "PIN",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Set Or Reset Card PIN",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://sandbox.interswitchng.com/card-360/api/v1/cards/:cardId/pin",
            "params": [
              {
                "name": "cardId",
                "value": "",
