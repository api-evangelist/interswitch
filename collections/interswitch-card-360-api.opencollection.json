            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Issue a new Verve, debit, or prepaid card to a customer profile."
        },
        {
          "info": {
            "name": "Get Card",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://sandbox.interswitchng.com/card-360/api/v1/cards/:cardId",
            "params": [
              {
                "name": "cardId",
                "value": "",
