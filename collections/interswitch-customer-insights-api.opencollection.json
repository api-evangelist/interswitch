                "name": "customerId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get Average Financial History"
        }
      ]
    },
    {
      "info": {
        "name": "Financial Habits",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get Financial Habits",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://sandbox.interswitchng.com/insights/api/v1/customers/:customerId/financial-habits",
            "params": [
              {
                "name": "customerId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get Financial Habits"
        }
      ]
    }
  ],
  "bundled": true
