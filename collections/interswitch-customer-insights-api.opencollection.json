              },
              {
                "name": "months",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Get Financial History"
        },
        {
          "info": {
            "name": "Get Average Financial History",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://sandbox.interswitchng.com/insights/api/v1/customers/:customerId/financial-history/average",
