              }
            ]
          },
          "docs": "Get Card"
        },
        {
          "info": {
            "name": "Block Card",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://sandbox.interswitchng.com/card-360/api/v1/cards/:cardId/block",
