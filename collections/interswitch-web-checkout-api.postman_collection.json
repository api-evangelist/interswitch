              "body": "{\n  \"ResponseCode\": \"string\",\n  \"Amount\": 7214,\n  \"TransactionDate\": \"1975-04-25T06:53:42.742Z\",\n  \"MerchantReference\": \"string\",\n  \"PaymentReference\": \"string\",\n  \"RetrievalReferenceNumber\": \"string\",\n  \"CardNumber\": \"string\",\n  \"LeadBankCbnCode\": \"string\",\n  \"LeadBankName\": \"string\"\n}",
