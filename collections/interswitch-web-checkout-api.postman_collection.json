    {
      "id": "14803105-58d7-4d3d-aad2-8f2a8c73e582",
      "name": "Transactions",
      "description": {
        "content": "Transaction status query",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "c34566de-9d90-451d-bacd-0a2765ee179b",
          "name": "Get Transaction Status",
          "request": {
            "name": "Get Transaction Status",
            "description": {
              "content": "Server-side transaction requery. Returns the authoritative status,\nresponse code, and amount for a given transaction reference. Must be\ncalled before delivering value; do not rely on the browser redirect\nparameters.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "collections",
                "api",
                "v1",
                "gettransaction.json"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "merchantcode",
                  "value": "<string>",
                  "description": "(Required) Merchant code issued by Interswitch."
                },
                {
                  "disabled": false,
                  "key": "transactionreference",
                  "value": "<string>",
                  "description": "(Required) Original `txn_ref` submitted at checkout."
                },
                {
                  "disabled": false,
                  "key": "amount",
                  "value": "<integer>",
                  "description": "(Required) Original transaction amount in minor units (kobo)."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
          "response": [
            {
              "id": "0a8e7a38-0b5c-4470-8e11-a7aadde7140d",
              "name": "Transaction status.",
              "originalRequest": {
                "url": {
                  "path": [
                    "collections",
                    "api",
                    "v1",
                    "gettransaction.json"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "query": [
                    {
                      "key": "merchantcode",
                      "value": "<string>"
                    },
                    {
                      "key": "transactionreference",
                      "value": "<string>"
                    },
                    {
                      "key": "amount",
                      "value": "<integer>"
                    }
                  ],
                  "variable": []
                },
                "header": [
                  {
                    "description": {
                      "content": "Added as a part of security scheme: apikey",
                      "type": "text/plain"
                    },
                    "key": "Authorization",
                    "value": "<API Key>"
                  },
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "method": "GET",
                "body": {}
              },
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
