{
  "info": {
    "_postman_id": "59a66848-0a38-477d-b38f-f1a1f1c0f1e7",
    "name": "Interswitch Web Checkout API",
    "description": "Interswitch Web Checkout (formerly Webpay) is the company's hosted payment\ngateway. Two integration modes are supported: an inline JavaScript popup\nloaded from `inline-checkout.js`, and a Web Redirect form POST to\n`/collections/w/pay`. After payment, merchants must perform a server-side\nrequery against `/collections/api/v1/gettransaction.json` and verify both\nthe response code (`00`) and the returned amount before delivering value.\n\n\nContact Support:\n Name: Interswitch Developer Support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T15:09:54.000Z",
    "updatedAt": "2026-06-05T15:09:54.000Z",
    "lastUpdatedBy": "35240",
    "uid": "35240-59a66848-0a38-477d-b38f-f1a1f1c0f1e7"
  },
