{
  "opencollection": "1.0.0",
  "info": {
    "name": "Interswitch Card 360 API",
    "version": "2024-01-01"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Cards",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Create Card",
            "type": "http"
          },
          "http": {
            "method": "POST",
